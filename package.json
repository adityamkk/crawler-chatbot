    "stop-qdrant": "docker stop qdrant",
    "start": "npx tsc && node dist/index.js",
    "ingest": "npx tsc && node dist/ingest.js",
    "ingest-cron": "npx tsc && node dist/ingest_cron.js start",
    "stop-ingest-cron": "npx tsc && node dist/ingest_cron.js stop",
    "build-qdrant": "docker run -d --name qdrant -p 6333:6333 -p 6334:6334 -v qdrant_storage:/qdrant/storage qdrant/qdrant",
    "dev": "docker compose up --build",
    "stop-dev": "docker compose down"
